# ── LicenseLight Environment Variables ────────────────────────────

# Application
SECRET_KEY=change-me-to-a-random-string
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://licenselight:licenselight@localhost:5432/licenselight

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Anthropic Claude API
CLAUDE_API_KEY=sk-ant-api03-your-key-here

# Google Custom Search API
# 1. Get API key at https://console.cloud.google.com/apis/credentials
# 2. Create a Custom Search Engine at https://programmablesearchengine.google.com/
#    - Configure it to search the entire web (not just specific sites)
#    - Enable "Image Search" in the CSE settings
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
